#!/usr/bin/env bash
set -euo pipefail

# @claude_pane_waiting on panes = source of truth (avoids inheriting from window)
# @claude_waiting on windows = display cache for status bar format strings

notify() {
  # Bell + sound (afplay is macOS-only)
  printf '\a'
  if command -v afplay &>/dev/null; then afplay /System/Library/Sounds/Ping.aiff & disown; fi

  # Need TMUX_PANE to set marker
  [[ -z "${TMUX_PANE:-}" ]] && return 0

  # Skip if pane is already visible and focused
  local info
  info=$(tmux display -t "$TMUX_PANE" -p '#{pane_active} #{window_active} #{session_attached}' 2>/dev/null) || return 0
  [[ "$info" == "1 1 1" ]] && return 0

  # Get window target and set options
  local target
  target=$(tmux display -t "$TMUX_PANE" -p '#{session_name}:#{window_index}') || return 0
  tmux set-option -p -t "$TMUX_PANE" @claude_pane_waiting 1
  tmux set-option -w -t "$target" @claude_waiting 1
}

clear_pane() {
  local pane_id="$1"

  # Unset pane option (may already be gone if pane exited)
  tmux set-option -pu -t "$pane_id" @claude_pane_waiting 2>/dev/null || true

  # Get window target
  local target
  target=$(tmux display -t "$pane_id" -p '#{session_name}:#{window_index}' 2>/dev/null) || return 0

  # If no panes in this window still waiting, unset window option
  local remaining
  remaining=$(tmux list-panes -t "$target" -f '#{@claude_pane_waiting}' -F x 2>/dev/null) || true
  if [[ -z "$remaining" ]]; then
    tmux set-option -wu -t "$target" @claude_waiting 2>/dev/null || true
  fi
}

clear_window() {
  local target="$1"
  local remaining
  remaining=$(tmux list-panes -t "$target" -f '#{@claude_pane_waiting}' -F x 2>/dev/null) || true
  if [[ -z "$remaining" ]]; then
    tmux set-option -wu -t "$target" @claude_waiting 2>/dev/null || true
  fi
}

clear_all() {
  tmux list-panes -a -f '#{@claude_pane_waiting}' -F '#{pane_id}' 2>/dev/null |
    while IFS= read -r p; do
      tmux set-option -pu -t "$p" @claude_pane_waiting 2>/dev/null || true
    done
  tmux list-windows -a -f '#{@claude_waiting}' -F '#{session_name}:#{window_index}' 2>/dev/null |
    while IFS= read -r w; do
      tmux set-option -wu -t "$w" @claude_waiting 2>/dev/null || true
    done
}

case "${1:-}" in
  clear)        clear_pane "${2:?usage: claude-notify clear <pane_id>}" ;;
  clear-window) clear_window "${2:?usage: claude-notify clear-window <target>}" ;;
  clear-all)    clear_all ;;
  "")           notify ;;
  *)            echo "usage: claude-notify [clear <pane_id> | clear-window <target> | clear-all]" >&2; exit 1 ;;
esac
